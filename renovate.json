{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "kubernetes": {
    "fileMatch": ["\\.yml$"]
  },
  "argocd": {
    "fileMatch": ["\\.yml$"]
  },
  "assignees": [
    "villepaukkunen"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/plan.yml/"],
      "matchStrings": ["(?<currentValue>\\S+)"],
      "depNameTemplate": "k3s",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>\\+k3s)(?<build>\\d+)$",
      "datasourceTemplate": "custom.k3s"
    }
  ],
  "customDatasources": {
    "k3s": {
      "defaultRegistryUrlTemplate": "https://update.k3s.io/v1-release/channels",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $$.(data[id = 'stable'].latest),\"sourceUrl\":\"https://github.com/k3s-io/k3s\",\"changelogUrl\":$join([\"https://github.com/k3s-io/k3s/releases/tag/\",data[id = 'stable'].latest])}],\"sourceUrl\": \"https://github.com/k3s-io/k3s\",\"homepage\": \"https://k3s.io/\"}"
      ]
    }
  },
  "packageRules": [
    {
      "matchDatasources": ["docker", "helm"],
      "matchUpdateTypes": ["major", "minor"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchPackageNames": [
        "jenkins",
        "portainer",
        "traefik"
      ],
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "1 days"
    },
    {
      "matchPackageNames": ["longhorn"],
      "matchUpdateTypes": ["patch"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchPackageNames": [
        "authentik",
        "cert-manager",
        "docker.io/library/nextcloud",
        "ghcr.io/immich-app/*",
        "docker.io/jellyfin/jellyfin",
        "ghcr.io/kube-vip/kube-vip",
        "quay.io/argoproj/argocd",
        "longhorn",
        "ghcr.io/connorgallopo/tracearr"
      ],
      "allowedVersions": "!/^v?[0-9]+\\.[0-9]+\\.0$/"
    },
    {
      "matchPackageNames": [
        "portainer"
      ],
      "allowedVersions": "!/^v?[0-9]+\\.0\\.[0-9]+$/"
    },
    {
      "matchPackageNames": [
        "argo-cd",
        "csi-driver-nfs",
        "docker.io/hkotel/mealie",
        "immich",
        "jenkins",
        "docker.io/linuxserver/*",
        "docker.io/nginx",
        "nextcloud",
        "portainer",
        "registry-1.docker.io/cloudpirates/*",
        "rke2-multus"
      ],
      "matchUpdateTypes": ["patch", "build", "revision"],
      "minimumReleaseAge": "1 days",
      "automerge": true,
      "ignoreTests": true
    },
    {
      "matchPackageNames": [
        "ghcr.io/immich-app/*",
        "ghcr.io/kube-vip/kube-vip",
        "docker.io/library/nextcloud",
        "ghcr.io/connorgallopo/tracearr"
      ],
      "minimumReleaseAge": "null"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.io/linuxserver/ddclient"],
      "versioning": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-ls(?<build>.+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/netbootxyz/netbootxyz"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-nbxyz(?<build>.+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.io/searxng/searxng"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(\\w+)$",
      "minimumReleaseAge": "3 days",
      "automerge": true,
      "ignoreTests": true
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.io/linuxserver/jellyfin"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)ubu(?<build>\\d+)-ls(?<revision>.+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.io/linuxserver/duplicati"],
      "versioning": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)_stable_(\\d{4}-\\d{2}-\\d{2})-ls(?<revision>.+)$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.io/villepaukkunen/inbound-agent"],
      "versioning": "regex:^(?<major>\\d+)\\.v(\\w+)-(?<patch>\\d+)$",
      "automerge": true,
      "ignoreTests": true
    }
  ]
}
